# Copy this file to .env and fill in your API keys

# Required: Covalent (GoldRush) API key
# Get free at https://www.covalenthq.com
COVALENT_API_KEY=your_covalent_api_key_here

# Optional: Etherscan API key (for ETH address labels)
# Get free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional: Moralis API key (for BSC address labels)
# Get free at https://moralis.io
MORALIS_API_KEY=your_moralis_api_key_here
